<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.uitpayapp">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_uitpay_demo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Androidstudioapp">
        <activity
            android:name=".notification.NotificationNewsActivity"
            android:exported="false" />
        <activity
            android:name=".notification.NotificationOrderActivity"
            android:exported="false" />
        <activity
            android:name=".notification.NotificationActivity"
            android:exported="false" />
        <activity
            android:name=".favorite.FavoriteActivity"
            android:exported="false" />
        <activity
            android:name=".home.HomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".history.TransactionHistoryActivity"
            android:exported="false">

        </activity>
        <activity
            android:name=".gift.GiftActivity"
            android:exported="false" />
        <activity
            android:name=".profile.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".auth.SignInActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".profile.InfoApplication"
            android:exported="false" />
        <activity
            android:name=".profile.NotificationSettings"
            android:exported="false" />
        <activity
            android:name=".profile.ProfileWebView"
            android:exported="false" />
        <activity
            android:name=".voucher.VoucherActivity"
            android:exported="false" />
        <activity
            android:name=".profile.ContactSupportActivity"
            android:exported="false" />
        <activity
            android:name=".auth.PasscodeActivity"
            android:exported="false" />
        <activity
            android:name=".YumYumPriority.PriorityYumYumActivity"
            android:exported="false" />
        <activity
            android:name=".giftexchange.GiftExchangeActivity"
            android:exported="false" />
        <activity
            android:name=".profile.accountPaymentManage.AccountManagementActivity"
            android:exported="false" />
        <activity
            android:name=".profile.AccountDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".deliveryaddressorder.AddressOrderActivity"
            android:exported="false" />
        <activity
            android:name=".recommendeddeal.RecommendedDealActivity"
            android:exported="false" />
        <activity
            android:name=".recommendeddeal.RecommendedDealDetailActivity"
            android:exported="false" />
        <activity
            android:name=".deliveryaddressorder.MapPickerActivity"
            android:exported="false" />
        <activity
            android:name=".registerstore.RegisterStoreActivity"
            android:exported="false" />
        <activity
            android:name=".home.CartActivity"
            android:exported="false" />
        <activity
            android:name=".home.checkout.FoodCheckoutActivity"
            android:exported="false" />
        <activity
            android:name=".home.checkout.TransferSuccessActivity"
            android:exported="false" />
        <activity
            android:name=".merchant.home.SellerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".merchant.shop.SellerShopActivity"
            android:exported="false" />
        <activity
            android:name=".merchant.shop.SellerReviewActivity"
            android:exported="false" />
        <activity
            android:name=".merchant.shop.MerchantMenuActivity"
            android:exported="false" />
        <activity
            android:name=".merchant.shop.AddMerchantDishActivity"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>
    </application>

</manifest>