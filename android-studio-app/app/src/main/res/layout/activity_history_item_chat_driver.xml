<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivDriverChatAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:src="@android:drawable/sym_action_call"
        app:shapeAppearanceOverlay="@xml/rounded_corners_small"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toRightOf="@id/ivDriverChatAvatar"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="48dp"
        android:gravity="start">

        <TextView
            android:id="@+id/tvDriverSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tài xế"
            android:textColor="#888888"
            android:textSize="11sp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#F0F0F0"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvDriverChatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Ok mình nhận đơn rồi nhé bạn"
                android:textColor="#222222"
                android:textSize="14sp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</RelativeLayout>