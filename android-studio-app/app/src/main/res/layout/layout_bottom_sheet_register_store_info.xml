<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#f5f7fa"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#ffffff">

        <ImageView
            android:id="@+id/btn_close_store_info_sheet"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:tint="#757575"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thông tin cửa hàng"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên cửa hàng"
                android:textColor="#757575"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/et_store_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext_rounded"
                android:hint="Nhập tên cửa hàng..."
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textSize="14sp"
                android:inputType="text"
                android:maxLines="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Số điện thoại quán"
                android:textColor="#757575"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/et_store_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext_rounded"
                android:hint="Nhập số điện thoại..."
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textSize="14sp"
                android:inputType="phone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Địa chỉ quán"
                android:textColor="#757575"
                android:textSize="13sp"/>

            <RelativeLayout
                android:id="@+id/layout_select_store_address"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext_rounded"
                android:paddingHorizontal="16dp">
                <TextView
                    android:id="@+id/tv_selected_store_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/iv_chevron_address"
                    android:text="Chọn địa chỉ từ bản đồ"
                    android:textColor="#9E9E9E"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <ImageView
                    android:id="@+id/iv_chevron_address"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_right_arrow"
                    app:tint="#9E9E9E"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Loại hình kinh doanh"
                android:textColor="#757575"
                android:textSize="13sp"/>

            <RelativeLayout
                android:id="@+id/layout_select_store_type"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext_rounded"
                android:paddingHorizontal="16dp">
                <TextView
                    android:id="@+id/tv_selected_store_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/iv_chevron_type"
                    android:text="Chọn loại hình quán"
                    android:textColor="#9E9E9E"
                    android:textSize="14sp"/>
                <ImageView
                    android:id="@+id/iv_chevron_type"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_right_arrow"
                    app:tint="#9E9E9E"
                    android:rotation="90"/>
            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_save_store_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_login_rounded"
                android:text="Lưu thông tin"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
