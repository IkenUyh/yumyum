<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/schemas/android/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true"
    tools:context=".PasscodeActivity">

    <TextView
        android:id="@+id/btn_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="✕"
        android:textColor="#000000"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layout_user_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/btn_close"
        tools2:layout_editor_absoluteX="-16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#E0E0E0"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_dog_kid" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Username"
            android:textColor="#0A1C40"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_phone_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="+849****126"
            android:textColor="#757575"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nhập mật khẩu ZaloPay để đăng nhập"
            android:textColor="#212121"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_user_info">

        <TextView
            android:id="@+id/tv_dot_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="○"
            android:textColor="#BDBDBD"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tv_dot_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="○"
            android:textColor="#BDBDBD"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tv_dot_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="○"
            android:textColor="#BDBDBD"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tv_dot_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="○"
            android:textColor="#BDBDBD"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tv_dot_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="○"
            android:textColor="#BDBDBD"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/dot_6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="○"
            android:textColor="#BDBDBD"
            android:textSize="30sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_error_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Mã Pin không đúng. Vui lòng thử lại."
        android:textColor="#E53935"
        android:textSize="15sp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_dots" />

    <TextView
        android:id="@+id/btn_forgot_pass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Quên mật khẩu?"
        android:textColor="#0052CC"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_error_message" />

    <TextView
        android:id="@+id/btn_not_my_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Đây không phải tài khoản của tôi"
        android:textColor="#0052CC"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.454"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_forgot_pass" />

    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#D2D5DC"
        android:columnCount="3"
        android:padding="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="1" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text=" " android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="2" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="A B C" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="3" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="D E F" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="4" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="G H I" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="5" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="J K L" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="6" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="M N O" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="7" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="P Q R S" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="8" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="T U V" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="9" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="W X Y Z" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <Space android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" />

        <LinearLayout android:id="@+id/btn_0" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="0" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text=" " android:textSize="10sp" />
        </LinearLayout>

        <TextView android:id="@+id/btn_delete" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="#00000000" android:gravity="center" android:text="⌫" android:textColor="#000000" android:textSize="28sp" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>