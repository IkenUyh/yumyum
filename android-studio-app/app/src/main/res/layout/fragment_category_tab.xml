<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/layout_category_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone">
        <include layout="@layout/layout_food_item_shimmer" />
        <include layout="@layout/layout_food_item_shimmer" />
        <include layout="@layout/layout_food_item_shimmer" />
        <include layout="@layout/layout_food_item_shimmer" />
        <include layout="@layout/layout_food_item_shimmer" />
    </LinearLayout>

    <!-- Error state -->
    <LinearLayout
        android:id="@+id/layout_category_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone"
        android:padding="24dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#F44336" />

        <TextView
            android:id="@+id/tv_category_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Đã xảy ra lỗi"
            android:textColor="#757575"
            android:textAlignment="center"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_category_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Thử lại"
            android:textColor="#FFFFFF"
            app:backgroundTint="#f24405" />
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layout_category_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone"
        android:padding="24dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="#9E9E9E" />

        <TextView
            android:id="@+id/tv_category_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Chưa có món ăn nào trong danh mục này"
            android:textColor="#757575"
            android:textAlignment="center"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Content (RecyclerView with SwipeRefresh) -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_category"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_category_foods"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</FrameLayout>
