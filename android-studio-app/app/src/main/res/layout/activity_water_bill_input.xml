<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:id="@+id/water_bill_input_container">

    <include layout="@layout/layout_top_bar"
        android:id="@+id/top_bar_water_input" />
    <LinearLayout
        android:id="@+id/layout_water_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar_water_input"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_provider_name_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nước Hồ Chí Minh"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_water_customer_code"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:hint="Mã khách hàng"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_select_sub_provider"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:gravity="center_vertical"
            android:hint="Chọn nhà cung cấp >"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:textSize="16sp"
            app:drawableTint="#757575"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hóa đơn mẫu"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/ic_receipt"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:background="#FFFFFF"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <include layout="@layout/layout_service_bill_result"
        android:id="@+id/water_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar_water_input"
        android:layout_margin="16dp"
        android:visibility="gone"/>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_water_action"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:background="@drawable/bg_button_login_rounded"
        android:text="Tiếp tục"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</RelativeLayout>
