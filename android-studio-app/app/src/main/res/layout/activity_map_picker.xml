<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/map_picker_container">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <include layout="@layout/layout_top_bar"
            android:id="@+id/top_bar_map_picker" />
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <org.osmdroid.views.MapView
                android:id="@+id/map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_map_pin"
                android:scaleType="centerCrop"
                android:translationY="-50dp"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@drawable/bg_button_login_rounded"
        android:backgroundTint="#40000000"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="85dp"
        android:layout_marginHorizontal="20dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            app:tint="#757575"/>
        <EditText
            android:id="@+id/et_search_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:hint="Tìm kiếm ưu đãi, thương hiệu"
            android:background="@null"
            android:textSize="14sp"
            android:textColor="#000000"
            android:textColorHint="#757575"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:importantForAutofill="no"/>
    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="16dp">
        <ImageView
            android:id="@+id/map_picker_finish"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_white_circle"
            android:backgroundTint="#40000000"
            android:padding="12dp"
            android:src="@drawable/ic_check"
            app:tint="#FFFFFF"
            android:layout_alignParentStart="true"/>
        <ImageView
            android:id="@+id/map_picker_current_location"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_white_circle"
            android:backgroundTint="#40000000"
            android:padding="12dp"
            android:src="@drawable/ic_gps_fixed"
            app:tint="#FFFFFF"
            android:layout_alignParentEnd="true"
            android:foreground="?android:attr/selectableItemBackground"/>
    </RelativeLayout>
</RelativeLayout>