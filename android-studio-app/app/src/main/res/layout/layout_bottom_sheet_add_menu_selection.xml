<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:background="#DDDDDD" />

    <TextView
        android:id="@+id/tv_sheet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:text="Thêm món"
        android:textColor="#333333"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_add_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_login_rounded"
        android:backgroundTint="#F5F5F5"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:text="Thêm danh mục món"
        android:textColor="#333333"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/btn_add_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_login_rounded"
        android:backgroundTint="#F5F5F5"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:text="Thêm món ăn"
        android:textColor="#333333"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/btn_cancel_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:padding="12dp"
        android:text="Hủy"
        android:textColor="#999999"
        android:textSize="16sp" />

</LinearLayout>
