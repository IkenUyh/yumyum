<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_white_rounded_corner"
    android:padding="24dp">

    <ViewFlipper
        android:id="@+id/vf_withdraw_steps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inAnimation="@android:anim/slide_in_left"
        android:outAnimation="@android:anim/slide_out_right">

        <!-- Step 1: Chọn phương thức -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chọn phương thức rút tiền"
                android:textColor="#333333"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:id="@+id/ll_method_personal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/bg_border_gray"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Điều chuyển về Ví Cá Nhân"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_method_bank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/bg_border_gray"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rút về Tài khoản Ngân hàng"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <Button
                android:id="@+id/btn_cancel_step1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hủy"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#757575"
                android:layout_marginTop="16dp" />

        </LinearLayout>

        <!-- Step 2: Nhập số tiền -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btn_back_step2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quay lại"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tv_step2_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập số tiền"
                    android:textColor="#333333"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_available_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Số dư khả dụng: 0đ"
                android:textColor="#666666"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/edt_withdraw_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="0"
                    android:inputType="number"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:background="@drawable/bg_border_gray"
                    android:paddingEnd="100dp"
                    android:gravity="center_vertical|end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="đ"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_alignEnd="@id/edt_withdraw_amount"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/tv_withdraw_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toàn bộ"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:layout_alignStart="@id/edt_withdraw_amount"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>

            </RelativeLayout>

            <Button
                android:id="@+id/btn_confirm_withdraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Xác nhận rút tiền"
                android:padding="14dp"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
