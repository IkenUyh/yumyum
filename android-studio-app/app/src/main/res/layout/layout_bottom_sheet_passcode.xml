<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_top_white"
    android:orientation="vertical"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/btn_close_passcode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:text="✕"
            android:textColor="#000000"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nhập mật khẩu"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_pin_indicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal">

        <View android:id="@+id/dot_1" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_circle_gray" />
        <View android:id="@+id/dot_2" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_circle_gray" />
        <View android:id="@+id/dot_3" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_circle_gray" />
        <View android:id="@+id/dot_4" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_circle_gray" />
        <View android:id="@+id/dot_5" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_circle_gray" />
        <View android:id="@+id/dot_6" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_circle_gray" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/keypad_passcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D2D5DC"
        android:columnCount="3"
        android:padding="3dp"
        android:layout_marginTop="16dp">

        <LinearLayout android:id="@+id/btn_pin_1" android:tag="1" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="1" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text=" " android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_2" android:tag="2" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="2" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="A B C" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_3" android:tag="3" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="3" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="D E F" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_4" android:tag="4" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="4" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="G H I" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_5" android:tag="5" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="5" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="J K L" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_6" android:tag="6" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="6" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="M N O" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_7" android:tag="7" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="7" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="P Q R S" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_8" android:tag="8" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="8" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="T U V" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_pin_9" android:tag="9" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="9" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="W X Y Z" android:textColor="#000000" android:textSize="10sp" />
        </LinearLayout>

        <Space android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" />

        <LinearLayout android:id="@+id/btn_pin_0" android:tag="0" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="@drawable/bg_keypad_button" android:elevation="2dp" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text="0" android:textColor="#000000" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:text=" " android:textSize="10sp" />
        </LinearLayout>

        <TextView android:id="@+id/btn_pin_delete" android:layout_width="0dp" android:layout_height="58dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="3dp" android:background="#00000000" android:gravity="center" android:text="⌫" android:textColor="#000000" android:textSize="28sp" />
    </GridLayout>
</LinearLayout>