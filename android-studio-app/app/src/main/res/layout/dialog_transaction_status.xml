<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp"
    android:gravity="center">

    <!-- Status Icon -->
    <ImageView
        android:id="@+id/iv_status_icon"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_circle_check"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/pb_status_loading"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:indeterminateTint="#F24405"
        android:layout_marginBottom="16dp"
        android:visibility="visible" />

    <!-- Status Title -->
    <TextView
        android:id="@+id/tv_status_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đang kiểm tra giao dịch"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="8dp" />

    <!-- Status Description -->
    <TextView
        android:id="@+id/tv_status_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hệ thống đang kiểm tra trạng thái giao dịch nạp tiền, vui lòng chờ trong giây lát..."
        android:textSize="15sp"
        android:textColor="#555555"
        android:textAlignment="center"
        android:layout_marginBottom="24dp" />

    <!-- Buttons Layout -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_status_close"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_login_rounded"
            android:backgroundTint="#EEEEEE"
            android:text="Hủy"
            android:textColor="#555555"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_status_action"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_login_rounded"
            android:backgroundTint="#F24405"
            android:text="Đồng ý"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
