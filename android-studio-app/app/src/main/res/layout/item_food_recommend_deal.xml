<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">
        <RelativeLayout
            android:id="@+id/layout_store_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:id="@+id/iv_store_location"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                android:layout_alignParentStart="true"
                app:tint="#757575"
                android:layout_centerVertical="true"/>

            <TextView
                android:id="@+id/tv_store_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Gà Rán Popeyes - Võ Văn Ngân"
                android:textColor="#424242"
                android:textSize="11sp"
                android:layout_toEndOf="@id/iv_store_location"
                android:maxWidth="230dp"/>

            <LinearLayout
                android:id="@+id/ll_distance_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true">
                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9.1km"
                    android:textColor="#757575"
                    android:textSize="11sp" />
                <View
                    android:id="@+id/v_distance_divider"
                    android:layout_width="1dp"
                    android:layout_height="10dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="#BDBDBD"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/tv_delivery_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42 phút"
                    android:textColor="#757575"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#f24405"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_image_container"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="12dp">
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:id="@+id/iv_food_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="#E0E0E0" />
                    <TextView
                        android:id="@+id/tv_discount_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#FFD600"
                        android:padding="4dp"
                        android:text="-52%"
                        android:textColor="#000000"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/cv_image_container"
                android:layout_marginStart="8dp"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/tv_food_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="1 MIẾNG GÀ RÁN GIÒN + 1 GÀ POPCORN + 1 KHOAI TÂY CHIÊN"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/ll_sold_info"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_fire"
                                app:tint="#f20c36"/>
                            <TextView
                                android:id="@+id/tv_sold_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="100K+ Đã bán"
                                android:textColor="#FF5722"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tv_original_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="118.000đ"
                            android:textColor="#BDBDBD"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_discount_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="57.000đ"
                            android:textColor="#EE4D2D"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btn_buy_now"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_login_rounded"
                        android:backgroundTint="#EE4D2D"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Mua ngay"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>