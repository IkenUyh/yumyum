<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">
            <TextView
                android:id="@+id/tvOrderHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đồ ăn #05066-620675729"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Hôm nay 17:14"
                android:textColor="#999999"
                android:textSize="12sp" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#EFEFEF"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="10dp">
            <TextView
                android:id="@+id/tvFavoriteTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#EE4D2D"
                android:text="Yêu thích"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:layout_marginRight="6dp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvMerchantName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bun Burrito - Trần Quốc Toản"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:id="@+id/layoutSingleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_toLeftOf="@id/layoutPriceBlock"
                android:layout_marginRight="10dp"
                android:layout_marginEnd="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivFoodImage"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:shapeAppearanceOverlay="@xml/rounded_corners_small"/>

                <TextView
                    android:id="@+id/tvFoodItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:text="Tên món ăn đơn lẻ"
                    android:textColor="#333333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSubItemsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toLeftOf="@id/layoutPriceBlock"
                android:orientation="horizontal"
                android:visibility="gone"
                android:nestedScrollingEnabled="false"/>

            <LinearLayout
                android:id="@+id/layoutPriceBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/tvFoodPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="61.000đ"
                    android:textColor="#222222"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvFoodCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 món ›"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#EFEFEF"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/tvPickupStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Đã lấy"
                android:textColor="#222222"
                android:textSize="14sp" />
            <LinearLayout
                android:id="@+id/layoutActiveStatusBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="vertical"
                android:gravity="end"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tvOrderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đơn đang được giao..."
                    android:textColor="#222222"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/layoutButtons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btnRate"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="ĐÁNH GIÁ"
                    android:textColor="#EE4D2D"
                    android:textSize="12sp"
                    app:strokeColor="#EE4D2D"
                    android:layout_marginRight="8dp"
                    android:paddingHorizontal="10dp"/>
                <Button
                    android:id="@+id/btnReorder"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:backgroundTint="#EE4D2D"
                    android:text="ĐẶT LẠI"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutWarningBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:orientation="horizontal"
            android:padding="8dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Đánh giá trong vòng 4 ngày để nhận 500 Shopee Xu"
                android:textColor="#666666"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>