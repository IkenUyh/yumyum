<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".history.ChatActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutChatHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#444444"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnHelpChat"
            app:layout_constraintStart_toEndOf="@id/btnBackChat"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat với Tài xế"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cơm Chiên Dương Châu | Mã đơn: 05066"
                android:textColor="#777777"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnHelpChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_help"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#E84A26"
            tools:ignore="ContentDescription" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/layoutChatHeader"
        app:layout_constraintBottom_toTopOf="@id/layoutQuickReplies" />

    <HorizontalScrollView
        android:id="@+id/layoutQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#F5F5F5"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/viewInputDivider">

        <LinearLayout
            android:id="@+id/lnQuickRepliesContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Xin chào!"
                android:textColor="#EE4D2D"
                android:textSize="13sp"
                android:background="@drawable/bg_dialog_rounded"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginRight="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="OK"
                android:textColor="#444444"
                android:textSize="13sp"
                android:background="@drawable/bg_dialog_rounded"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginRight="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_dialog_rounded"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Tôi chưa nhận được hàng"
                android:textColor="#444444"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Đợi một chút..."
                android:textColor="#444444"
                android:textSize="13sp"
                android:background="@drawable/bg_dialog_rounded"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:id="@+id/viewInputDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EFEFEF"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomInputBar"/>

    <LinearLayout
        android:id="@+id/layoutBottomInputBar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnGridMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_add"
            app:tint="#777777"
            tools:ignore="ContentDescription" />

        <EditText
            android:id="@+id/etChatMessageInput"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:background="@android:drawable/edit_text"
            android:hint="Nhập tin nhắn"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:inputType="textShortMessage" />

        <ImageButton
            android:id="@+id/btnSendMessage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#EE4D2D"
            tools:ignore="ContentDescription" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>