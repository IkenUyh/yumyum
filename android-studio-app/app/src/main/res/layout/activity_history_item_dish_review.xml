<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp">

    <androidx.cardview.widget.CardView
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgDishThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:color/darker_gray"
            android:contentDescription="Dish thumbnail" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtDishName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:text="Tên món ăn"
        android:textColor="#212121"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/btnDislike"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:src="@drawable/thumb_down_24px"
        android:background="@android:color/transparent"
        android:layout_marginEnd="12dp"
        android:contentDescription="Dislike button" />

    <ImageView
        android:id="@+id/btnLike"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:src="@drawable/thumb_up_24px"
        android:background="@android:color/transparent"
        android:contentDescription="Like button" />

</LinearLayout>