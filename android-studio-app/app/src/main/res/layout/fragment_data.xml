<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_top_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TABS CHUYỂN ĐỔI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/tv_tab_nap_data"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="Nạp data"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tab_the_data"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="Thẻ data"
                android:textColor="#757575"
                android:textStyle="normal" />
        </LinearLayout>

        <!-- KHU VỰC 1: NẠP DATA -->
        <LinearLayout
            android:id="@+id/layout_nap_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Khung nhập SĐT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/iv_carrier_logo_data"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_dog_kid"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_contact_data"
                        app:layout_constraintStart_toEndOf="@id/iv_carrier_logo_data"
                        app:layout_constraintTop_toTopOf="parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số của tôi"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                        <EditText
                            android:id="@+id/et_phone_number_data"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:inputType="phone"
                            android:text="0329815572"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <ImageView
                        android:id="@+id/iv_contact_data"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_edit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bộ lọc Nạp Data -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/filter_nap_all" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="Tất cả" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_nap_30d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="30 ngày" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_nap_7d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="7 ngày" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_nap_3d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="3 ngày" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_nap_1d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="1 ngày" android:textSize="14sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- KHỐI 1 NGÀY -->
            <TextView
                android:id="@+id/tv_header_nap_1_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 1 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_data_1_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:itemCount="4"
                tools:listitem="@layout/item_data_package" />

            <!-- KHỐI 3 NGÀY -->
            <TextView
                android:id="@+id/tv_header_nap_3_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 3 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_data_3_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:itemCount="2"
                tools:listitem="@layout/item_data_package" />

            <!-- KHỐI 7 NGÀY -->
            <TextView
                android:id="@+id/tv_header_nap_7_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 7 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_data_7_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:itemCount="2"
                tools:listitem="@layout/item_data_package" />

            <!-- KHỐI 30 NGÀY -->
            <TextView
                android:id="@+id/tv_header_nap_30_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 30 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_data_30_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:itemCount="2"
                tools:listitem="@layout/item_data_package" />

        </LinearLayout>

        <!-- KHU VỰC 2: THẺ DATA -->
        <LinearLayout
            android:id="@+id/layout_the_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 1. Chọn nhà mạng -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_carriers_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"
                tools:itemCount="3"
                tools:listitem="@layout/item_carrier" />

            <!-- Bộ lọc Thẻ Data -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/filter_the_all" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="Tất cả" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_the_30d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="30 ngày" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_the_7d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="7 ngày" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_the_3d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="3 ngày" android:textSize="14sp" />
                    <TextView android:id="@+id/filter_the_1d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="1 ngày" android:textSize="14sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- KHỐI 1 NGÀY -->
            <TextView
                android:id="@+id/tv_header_card_1_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 1 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_card_data_1_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"/>

            <!-- KHỐI 3 NGÀY -->
            <TextView
                android:id="@+id/tv_header_card_3_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 3 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_card_data_3_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"/>

            <!-- KHỐI 7 NGÀY -->
            <TextView
                android:id="@+id/tv_header_card_7_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 7 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_card_data_7_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"/>

            <!-- KHỐI 30 NGÀY -->
            <TextView
                android:id="@+id/tv_header_card_30_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gói 30 ngày"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_card_data_30_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"/>

            <!-- 3. Khung chọn Số lượng (Giữ nguyên) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8F9FA"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Số lượng"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/btn_minus_data"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_gray"
                            android:gravity="center"
                            android:text="-"
                            android:textColor="#BDBDBD"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_quantity_data"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/btn_plus_data"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_gray"
                            android:backgroundTint="#0A46A6"
                            android:gravity="center"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>