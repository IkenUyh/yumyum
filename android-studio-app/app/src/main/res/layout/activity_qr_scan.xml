<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">
    <com.journeyapps.barcodescanner.CompoundBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_preview_scaling_strategy="centerCrop"
        app:zxing_use_texture_view="true" />
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#40000000" />
        <RelativeLayout
            android:id="@+id/top_bar_qrScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center">
            <ImageView
                android:id="@+id/btn_close_scan"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_less_than"
                app:tint="#FFFFFF" />
            <ImageView
                android:id="@+id/qrscan_btn_flash"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_qr_scan_light"
                app:tint="#757575" />
        </RelativeLayout>
        <View
            android:id="@+id/qr_frame"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_qr_frame" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/qr_frame"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/isScanTransfer">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quốc gia: 🇻🇳 Việt Nam"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ngân hàng • VietQR • VietQR Pay • VNPAYQR"
                    android:textColor="#FAFAFA"
                    android:textSize="13sp" />
            </LinearLayout>
            <TextView
                android:id="@+id/isScanCCCD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:text="Quét mã trên Căn cước công dân"
                android:visibility="gone"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:background="@drawable/bg_white_circle"
                    android:backgroundTint="#40FFFFFF"
                    android:padding="12dp"
                    android:src="@drawable/ic_gear"
                    app:tint="#FFFFFF"/>
                <LinearLayout
                    android:id="@+id/qrscan_useimg_instore"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_button_login_rounded"
                    android:backgroundTint="#40FFFFFF"
                    android:layout_marginLeft="30dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_qr_scan_album"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tải ảnh"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="8dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>
