<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- HÀNG TRÊN -->
    <LinearLayout
        android:id="@+id/layoutTopRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tháng -->
        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tháng 10/2024"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Icon + text -->
        <LinearLayout
            android:id="@+id/layoutAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgHeaderAction"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:tint="#0C40CC"
                android:src="@drawable/ic_eye" />

            <TextView
                android:id="@+id/tvAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Hiện số dư"
                android:textColor="#0C40CC"
                android:textSize="18sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- SUMMARY -->
    <TextView
        android:id="@+id/tvSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tổng thu: ... | Tổng chi: ..."
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/layoutTopRow"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>