<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@android:drawable/stat_notify_call_mute"
        android:background="#E84A26"
        android:padding="6dp"
        app:shapeAppearanceOverlay="@xml/rounded_corners_small"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="32dp">

        <TextView
            android:id="@+id/tvSystemSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hỗ Trợ"
            android:textColor="#888888"
            android:textSize="12sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#F5F5F5"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvSystemText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Chào bạn, Tài xế sẽ nhận được tin nhắn của bạn ngay khi nhận đơn hàng..."
                android:textColor="#333333"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.1"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>