<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7"
    android:fillViewport="true"
    tools:context=".home.checkout.TransferSuccessActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF">

            <View
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/bg_success_gradient" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="48dp"
                android:paddingBottom="32dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iv_success_check"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#0bc36a"
                        app:strokeWidth="5dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/ic_bold_check"
                            app:tint="#0bc36a" />
                    </com.google.android.material.card.MaterialCardView>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:text="Giao dịch thành công"
                    android:textColor="#0bc36a"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_transaction_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã giao dịch: #260418004556544"
                        android:textColor="#757575"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_transaction_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Thời gian: 23:57 18/04/2026"
                        android:textColor="#757575"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_success_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text=""
                    android:textColor="#0A46A6"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    app:autoSizeMaxTextSize="56sp"
                    app:autoSizeMinTextSize="12sp"
                    app:autoSizeStepGranularity="2sp"
                    app:autoSizeTextType="uniform" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="#F8F9FA"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/iv_recipient_avatar_success"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img_usagi" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Hàng 1: Chứa Số Seri / Nhãn -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_label_recipient_success"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GỬI ĐẾN"
                                    android:textColor="#9E9E9E"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/iv_copy_seri"
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="8dp"
                                    android:padding="2dp"
                                    android:src="@drawable/ic_copy"
                                    android:visibility="gone"
                                    app:tint="#9E9E9E" />
                            </LinearLayout>

                            <!-- Hàng 2: Chứa Mã thẻ / Tên người nhận -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_recipient_name_success"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="USERNAME"
                                    android:textColor="#000000"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/iv_copy_pin"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:padding="2dp"
                                    android:src="@drawable/ic_copy"
                                    android:visibility="gone"
                                    app:tint="#0A46A6" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_transaction_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:text="Ghi chú:"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btn_close_action"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#F2F6FE"
                        android:text="Đóng"
                        android:textAllCaps="false"
                        android:textColor="#0A46A6"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp" />

                    <Button
                        android:id="@+id/btn_transaction_details"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#F2F6FE"
                        android:text="Chi tiết giao dịch"
                        android:textAllCaps="false"
                        android:textColor="#0A46A6"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="295dp"
                android:background="@drawable/bg_bottom_fade"
                android:orientation="vertical"
                android:padding="24dp">
            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_zigzag" />

        </FrameLayout>
    </LinearLayout>
</ScrollView>