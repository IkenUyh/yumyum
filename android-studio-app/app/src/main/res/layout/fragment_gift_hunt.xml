                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="2" android:ellipsize="end" android:text="Quét QR để đổi" android:textColor="#757575" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="110dp"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="12dp">
                                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:scaleType="fitCenter" android:src="@drawable/ic_sanqua_nenthom" />
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="2" android:ellipsize="end" android:text="Nến thơm MUJI" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="2" android:ellipsize="end" android:text="Quét QR để đổi" android:textColor="#757575" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="110dp"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="12dp">
                                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:scaleType="fitCenter" android:src="@drawable/ic_sanqua_fumo" />
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="2" android:ellipsize="end" android:text="Fumo Fumo" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="2" android:ellipsize="end" android:text="Quét QR để đổi" android:textColor="#757575" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="110dp"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="12dp">
                                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:scaleType="fitCenter" android:src="@drawable/ic_sanqua_kemduong" />
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="2" android:ellipsize="end" android:text="Kem tay Innisfree" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="2" android:ellipsize="end" android:text="Quét QR để đổi" android:textColor="#757575" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="110dp"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
