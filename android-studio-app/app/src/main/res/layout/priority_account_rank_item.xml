<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">
    <LinearLayout
        android:id="@+id/priority_account_rank_outer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="5dp"
        android:background="#10a941"
        android:backgroundTint="#B3FFFFFF"
        android:backgroundTintMode="screen">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp">
            <RelativeLayout
                android:id="@+id/priority_account_rank_inner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#10a941">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:id="@+id/priority_account_rank_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÀI KHOẢN MỚI"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/priority_account_rank_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_login_rounded"
                        android:backgroundTint="#40000000"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="Hạng Thành viên"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/rank_progress_bar_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:text="Thanh toán thêm 3.000.000đ để thăng hạng >"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:maxWidth="230dp"/>
                    <ProgressBar
                        android:id="@+id/rank_progress_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:progress="30"
                        android:max="100"
                        android:progressTint="#B3FFFFFF"
                        android:progressBackgroundTint="#40000000"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="20dp"
                    android:src="@drawable/ic_food_soup"
                    app:tint="#40FFFFFF"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp">
            <TextView
                android:id="@+id/btn_view_more_benefits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem thêm về các lợi ích khi thăng hạng >"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:id="@+id/rv_priority_rank"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            tools:listitem="@layout/menuitem_profile_screen"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>