<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:orientation="vertical">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cập nhật thông tin cửa hàng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/btn_close_update_shop_info"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:layout_alignParentEnd="true"
            app:tint="#000000"
            android:contentDescription="Close"/>
    </RelativeLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/et_shop_name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:hint="Tên cửa hàng"
                android:inputType="text"
                android:background="@drawable/bg_edittext_rounded"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"
                android:textColor="#000000"
                android:autofillHints="name" />

            <EditText
                android:id="@+id/et_shop_address"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:hint="Địa chỉ"
                android:inputType="textPostalAddress"
                android:background="@drawable/bg_edittext_rounded"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"
                android:textColor="#000000"
                android:autofillHints="postalAddress" />

            <EditText
                android:id="@+id/et_shop_phone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:background="@drawable/bg_edittext_rounded"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"
                android:textColor="#000000"
                android:autofillHints="phone" />

            <EditText
                android:id="@+id/et_shop_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_edittext_rounded"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"
                android:textColor="#000000"
                android:autofillHints="emailAddress" />

            <EditText
                android:id="@+id/et_shop_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginBottom="24dp"
                android:hint="Mô tả cửa hàng"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:background="@drawable/bg_edittext_rounded"
                android:padding="16dp"
                android:textSize="16sp"
                android:textColor="#000000" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_save_shop_update"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_login_rounded"
                android:text="Lưu thay đổi"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
