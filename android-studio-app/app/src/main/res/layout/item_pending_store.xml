<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:id="@+id/card_pending_store">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_store_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            android:layout_marginEnd="12dp"
            android:layout_centerVertical="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_store_image"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="1">
                
                <TextView
                    android:id="@+id/tv_store_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tên cửa hàng"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chờ duyệt"
                    android:textSize="12sp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/bg_badge_pending"
                    android:textColor="#F57C00"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_owner_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chủ: Nguyễn Văn A"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/tv_store_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loại hình: Đồ ăn"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"
                android:maxLines="1"/>
                
            <TextView
                android:id="@+id/tv_store_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Địa chỉ: 123 Đường ABC..."
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_date_submitted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ngày gửi: 20/05/2024"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="4dp"
                android:maxLines="1"/>

        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
