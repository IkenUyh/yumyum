<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivUserChatAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:src="@android:drawable/sym_def_app_icon"
        app:shapeAppearanceOverlay="@xml/rounded_corners_small"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toLeftOf="@id/ivUserChatAvatar"
        android:layout_marginRight="8dp"
        android:layout_marginLeft="48dp"
        android:gravity="end">

        <TextView
            android:id="@+id/tvUserSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="foodee_gl6s3niq"
            android:textColor="#888888"
            android:textSize="11sp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#1EA28A"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvUserChatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Chỗ em đang mưa to á"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</RelativeLayout>