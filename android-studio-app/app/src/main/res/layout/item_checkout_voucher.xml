<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:layout_marginTop="4dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="110dp"
        android:orientation="horizontal">
        <LinearLayout
            android:id="@+id/ll_left_side"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:background="#f24405"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ic_type_voucher"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_food"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tv_type_voucher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Giảm giá món"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>
        </LinearLayout>
        <RelativeLayout
            android:id="@+id/cl_right_side"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">
            <LinearLayout
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/tv_voucher_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Giảm 20.000đ cho đơn từ 20.000đ"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_voucher_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Đặt tối thiểu 20.000đ"
                    android:textColor="#757575"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btn_use_voucher"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_outline_red"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:text="Dùng"
                android:textColor="#EE4D2D"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
